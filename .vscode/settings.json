        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "client/eslint.config.js": true,
        "client/.gitignore": true,
        "client/src/index.jsx": true,
        "client/src/App.jsx": true,
        "client/node_modules": true,
